# Indexer
ATSEARCH_MODE=poll
ATSEARCH_PDS_URL=https://bsky.social
ATSEARCH_HANDLE=your-handle.bsky.social
ATSEARCH_PASSWORD=your-app-password
ATSEARCH_DHT_BOOTSTRAP=/ip4/127.0.0.1/tcp/8001/p2p/PEER_ID
ATSEARCH_HTTP_PORT=3001
ATSEARCH_DB_PATH=./data/indexer.db
ATSEARCH_NODE_KEY=

# Query node — Microcosm + XRPC (see README + MIGRATION_MICROCOSM.md)
USE_MICROCOSM=true
MICROCOSM_SLINGSHOT_BASE_URL=https://slingshot.microcosm.blue
MICROCOSM_CONSTELLATION_BASE_URL=https://constellation.microcosm.blue
FALLBACK_ATPROTO_XRPC_BASE_URL=https://public.api.bsky.app
APP_USER_AGENT=at-search-demo/0.1 (your-name; +https://your-project)

# ATSEARCH_DHT_BOOTSTRAP=/ip4/127.0.0.1/tcp/8001/p2p/PEER_ID
# ATSEARCH_HTTP_PORT=3002
# ATSEARCH_INDEXER_URLS=http://localhost:3001

# Demo Client
VITE_QUERY_API_URL=http://localhost:3002
